{
  "name": "@respira/cli-core",
  "version": "0.1.2",
  "description": "Shared utilities for Respira CLI for WordPress. Auth storage, output formatting, API client, error types.",
  "keywords": [
    "wordpress",
    "wordpress-cli",
    "respira",
    "cli"
  ],
  "homepage": "https://respira.press/cli",
  "bugs": "https://github.com/respira-press/respira-wordpress-cli/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/respira-press/respira-wordpress-cli.git",
    "directory": "packages/cli-core"
  },
  "license": "MIT",
  "author": "Mihai Dragomirescu <mihai@respira.press>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "keytar": "^7.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.3",
    "vitest": "^2.0.0"
  }
}
